{
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output/static",
  "functions": {
    ".vercel/output/functions/__server.func/index.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/__server.func" }
  ]
}